# Copie este arquivo para .env e preencha os valores
# Gere os segredos JWT com: openssl rand -hex 32

NODE_ENV=development
PORT=3001

# Para testar só no seu computador:
FRONTEND_URL=http://localhost:5173

# Para testar com um amigo na mesma rede (adicione o IP da sua máquina):
# FRONTEND_URL=http://localhost:5173,http://192.168.1.XXX:5173
# Descubra seu IP com: ipconfig (Windows) ou ip addr (Linux)

# JWT Secrets (min 256 bits)
JWT_ACCESS_SECRET=GERAR_COM_openssl_rand_hex_32
JWT_REFRESH_SECRET=GERAR_COM_openssl_rand_hex_32_DIFERENTE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SQLite
DATABASE_PATH=./data/jogocarta.db
